{
  "info": {
    "name": "Music Stuffs API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API REST para la plataforma educativa de música.\n\nDos tipos de acceso:\n  - {{baseUrl}}  → endpoints JSON (subir, consultar estado, loops, variantes)\n  - {{mediaUrl}} → archivos estáticos (HLS, audio, waveform, thumbnail, metadata)\n\nFlujo principal:\n  1. POST /videos/upload → { id }\n  2. GET  /videos/:id/status (polling hasta status=ready)\n  3. Reproducir HLS desde {{mediaUrl}}/{{videoId}}/index.m3u8\n  4. Cargar WAV desde GET /videos/:id/audio (para pitch/transpose en frontend)\n  5. Cargar waveform desde GET /videos/:id/waveform"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string",
      "description": "API REST (JSON)"
    },
    {
      "key": "mediaUrl",
      "value": "http://localhost:3001/media",
      "type": "string",
      "description": "Archivos estáticos servidos directamente por Express"
    },
    {
      "key": "videoId",
      "value": "",
      "type": "string",
      "description": "UUID del video — copiar del response de Upload video"
    },
    {
      "key": "loopId",
      "value": "",
      "type": "string",
      "description": "UUID de un loop — copiar del response de Create loop"
    },
    {
      "key": "variantId",
      "value": "",
      "type": "string",
      "description": "UUID de una variante de audio — copiar del response de Generate variant"
    }
  ],
  "item": [
    {
      "name": "1 · Videos — API",
      "description": "Endpoints JSON para subir y consultar videos.\n\nLos paths devueltos son relativos a VIDEO_BASE_DIR.\nEl frontend construye las URLs estáticas como {{mediaUrl}}/{path}.\n\nEl campo durationMs es la duración con precisión de milisegundos,\nútil para loop sample-accurate y sincronización audio/video.",
      "item": [
        {
          "name": "Upload video",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/videos/upload",
            "header": [
              {
                "key": "x-teacher-id",
                "value": "teacher-uuid-001",
                "description": "Opcional — ID del docente",
                "disabled": true
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": ".mp4 | .mov | .mkv — máx 500 MB"
                }
              ]
            }
          },
          "response": [
            {
              "name": "201 – Aceptado (procesando en background)",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\"\n}"
            },
            {
              "name": "400 – MIME no permitido",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 400,\n  \"message\": \"Tipo MIME no permitido: video/avi. Permitidos: video/mp4, video/quicktime, video/x-matroska\"\n}"
            },
            {
              "name": "400 – Archivo demasiado grande",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 400,\n  \"message\": \"Archivo demasiado grande: 600.0 MB (máximo: 500 MB)\"\n}"
            }
          ]
        },
        {
          "name": "Get video status (polling)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["videos", "{{videoId}}", "status"]
            }
          },
          "response": [
            {
              "name": "200 – processing",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"status\": \"processing\",\n  \"originalFilename\": \"clase-guitarra.mp4\",\n  \"durationMs\": null,\n  \"durationSeconds\": null,\n  \"resolution\": null,\n  \"hlsPath\": null,\n  \"audioWavPath\": null,\n  \"waveformPath\": null,\n  \"waveformLowPath\": null,\n  \"metadataPath\": null,\n  \"thumbnailPath\": null,\n  \"processingAttempts\": 1\n}"
            },
            {
              "name": "200 – ready",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"status\": \"ready\",\n  \"originalFilename\": \"clase-guitarra.mp4\",\n  \"durationMs\": 225340,\n  \"durationSeconds\": 225.34,\n  \"resolution\": \"1920x1080\",\n  \"hlsPath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/index.m3u8\",\n  \"audioWavPath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/audio.wav\",\n  \"waveformPath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/waveform.json\",\n  \"waveformLowPath\": null,\n  \"metadataPath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/metadata.json\",\n  \"thumbnailPath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/thumbnail.jpg\",\n  \"processingAttempts\": 1\n}"
            },
            {
              "name": "200 – failed",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"status\": \"failed\",\n  \"processingAttempts\": 3\n}"
            }
          ]
        },
        {
          "name": "Get audio WAV (pitch/transpose en frontend)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/audio",
              "host": ["{{baseUrl}}"],
              "path": ["videos", "{{videoId}}", "audio"]
            },
            "description": "Devuelve el audio en PCM 16-bit, 44.1 kHz, estéreo.\nUsar con AudioContext.decodeAudioData() para pitch shifting / transpose en el frontend.\nEl backend NO modifica el audio — siempre es el original."
          },
          "response": [
            {
              "name": "200 – audio/wav (PCM estéreo)",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "audio/wav" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
                { "key": "Accept-Ranges", "value": "bytes" }
              ],
              "body": "<binary WAV — PCM 16-bit 44.1 kHz estéreo>"
            },
            {
              "name": "400 – Video todavía processing",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 400,\n  \"message\": \"Video no disponible (estado: processing)\"\n}"
            },
            {
              "name": "404 – Sin audio (video mudo)",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 404,\n  \"message\": \"Audio WAV no disponible para este video\"\n}"
            }
          ]
        },
        {
          "name": "Get waveform JSON (high-res)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/waveform",
              "host": ["{{baseUrl}}"],
              "path": ["videos", "{{videoId}}", "waveform"]
            }
          },
          "response": [
            {
              "name": "200 – waveform.json (video ≤ 1h, ~20 000 pts)",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
              ],
              "body": "{\n  \"version\": 2,\n  \"channels\": 1,\n  \"sample_rate\": 44100,\n  \"samples_per_pixel\": 512,\n  \"bits\": 8,\n  \"length\": 19296,\n  \"data\": [-5, 12, -18, 9, 22, -30, \"...\"]\n}"
            },
            {
              "name": "200 – waveform-high.json (video > 1h, ~20 000 pts zoom)",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
              ],
              "body": "{\n  \"version\": 2,\n  \"channels\": 1,\n  \"sample_rate\": 44100,\n  \"samples_per_pixel\": 16384,\n  \"bits\": 8,\n  \"length\": 20000,\n  \"data\": [-5, 12, -18, 9, \"...\"]\n}"
            }
          ]
        },
        {
          "name": "Get waveform JSON (low-res, solo videos > 1h)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/waveform/low",
              "host": ["{{baseUrl}}"],
              "path": ["videos", "{{videoId}}", "waveform", "low"]
            }
          },
          "response": [
            {
              "name": "200 – waveform-low.json (~5 000 pts overview)",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
              ],
              "body": "{\n  \"version\": 2,\n  \"channels\": 1,\n  \"sample_rate\": 44100,\n  \"samples_per_pixel\": 65536,\n  \"bits\": 8,\n  \"length\": 5000,\n  \"data\": [-3, 8, -12, 6, \"...\"]\n}"
            },
            {
              "name": "404 – Video menor a 1 hora",
              "status": "Not Found",
              "code": 404,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 404,\n  \"message\": \"Waveform low-res no disponible (el video puede ser menor a 1 hora)\"\n}"
            }
          ]
        },
        {
          "name": "Get HLS stream — API",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/videos/{{videoId}}/stream",
              "host": ["{{baseUrl}}"],
              "path": ["videos", "{{videoId}}", "stream"]
            },
            "description": "Alternativa API al acceso estático directo.\nPreferir {{mediaUrl}}/{{videoId}}/index.m3u8 para reproductores HLS."
          },
          "response": [
            {
              "name": "200 – application/vnd.apple.mpegurl",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/vnd.apple.mpegurl" }],
              "body": "<playlist HLS>"
            }
          ]
        }
      ]
    },
    {
      "name": "2 · Archivos estáticos (/media)",
      "description": "Acceso directo a los archivos generados por Express static.\nEl reproductor HLS debe apuntar siempre a {{mediaUrl}}/{{videoId}}/index.m3u8.\n\nEstructura de archivos por video:\n  {videoId}/\n    index.m3u8        ← HLS playlist (VOD)\n    segment_000.ts    ← segmentos HLS (flat, sin subdirectorios)\n    segment_001.ts\n    audio.wav         ← PCM 16-bit 44.1 kHz estéreo\n    waveform.json     ← decimado ~20 000 pts\n    thumbnail.jpg\n    metadata.json     ← durationMs, resolution, audio specs",
      "item": [
        {
          "name": "HLS – index.m3u8",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/index.m3u8"
          },
          "response": [
            {
              "name": "200 – HLS VOD playlist",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/vnd.apple.mpegurl" }],
              "body": "#EXTM3U\n#EXT-X-VERSION:3\n#EXT-X-TARGETDURATION:4\n#EXT-X-MEDIA-SEQUENCE:0\n#EXT-X-PLAYLIST-TYPE:VOD\n#EXTINF:4.000000,\nsegment_000.ts\n#EXTINF:4.000000,\nsegment_001.ts\n#EXTINF:4.000000,\nsegment_002.ts\n...\n#EXT-X-ENDLIST"
            }
          ]
        },
        {
          "name": "HLS – segment_000.ts",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/segment_000.ts"
          },
          "response": [
            {
              "name": "200 – video/MP2T",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "video/MP2T" }],
              "body": "<binary TS segment>"
            }
          ]
        },
        {
          "name": "Audio WAV (estático directo)",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/audio.wav",
            "description": "Alternativa estática a GET /videos/:id/audio.\nMisma respuesta — PCM 16-bit 44.1 kHz estéreo."
          },
          "response": [
            {
              "name": "200 – audio/wav",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "audio/wav" }],
              "body": "<binary WAV — PCM 16-bit 44.1 kHz estéreo>"
            }
          ]
        },
        {
          "name": "Waveform JSON (video ≤ 1h)",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/waveform.json"
          },
          "response": []
        },
        {
          "name": "Waveform high-res JSON (video > 1h)",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/waveform-high.json"
          },
          "response": []
        },
        {
          "name": "Waveform low-res JSON (video > 1h)",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/waveform-low.json"
          },
          "response": []
        },
        {
          "name": "Metadata JSON",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/metadata.json"
          },
          "response": [
            {
              "name": "200 – metadata.json",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"videoId\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"originalFilename\": \"clase-guitarra.mp4\",\n  \"durationMs\": 225340,\n  \"durationSeconds\": 225.34,\n  \"resolution\": \"1920x1080\",\n  \"hasAudio\": true,\n  \"audio\": {\n    \"sampleRate\": 44100,\n    \"channels\": 2,\n    \"bitDepth\": 16,\n    \"format\": \"PCM\"\n  },\n  \"processedAt\": \"2026-02-24T00:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Thumbnail",
          "request": {
            "method": "GET",
            "url": "{{mediaUrl}}/{{videoId}}/thumbnail.jpg"
          },
          "response": [
            {
              "name": "200 – image/jpeg",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "image/jpeg" }],
              "body": "<binary JPEG>"
            }
          ]
        }
      ]
    },
    {
      "name": "3 · Loops A-B",
      "description": "Creación y consulta de loops A-B por video.\nLos tiempos se expresan en segundos (float).\nUsar durationMs del status para validar que endTime no supera la duración.",
      "item": [
        {
          "name": "Create loop",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/loops",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "loops"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user-uuid-001\",\n  \"startTime\": 42.5,\n  \"endTime\": 78.0,\n  \"label\": \"Puente de la canción\",\n  \"isPublic\": false,\n  \"isRecommended\": false\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "201 – Loop creado",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n  \"videoId\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"userId\": \"user-uuid-001\",\n  \"startTime\": 42.5,\n  \"endTime\": 78,\n  \"label\": \"Puente de la canción\",\n  \"isPublic\": false,\n  \"isRecommended\": false,\n  \"createdAt\": \"2026-02-24T00:10:00.000Z\",\n  \"updatedAt\": \"2026-02-24T00:10:00.000Z\"\n}"
            },
            {
              "name": "400 – endTime <= startTime",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 400,\n  \"message\": [\"endTime (30) debe ser mayor que startTime (42.5)\"]\n}"
            }
          ]
        },
        {
          "name": "Get loops by video (todos)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/loops",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "loops"],
              "query": [
                {
                  "key": "userId",
                  "value": "user-uuid-001",
                  "description": "Filtra loops de un usuario específico",
                  "disabled": true
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 – Lista ordenada por startTime",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": \"a1b2c3d4-e5f6-7890-abcd-ef1234567890\",\n    \"videoId\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n    \"userId\": \"user-uuid-001\",\n    \"startTime\": 42.5,\n    \"endTime\": 78,\n    \"label\": \"Puente de la canción\",\n    \"isPublic\": false,\n    \"isRecommended\": false,\n    \"createdAt\": \"2026-02-24T00:10:00.000Z\",\n    \"updatedAt\": \"2026-02-24T00:10:00.000Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Get loops by video + usuario (filtrado)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/loops?userId=user-uuid-001",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "loops"],
              "query": [{ "key": "userId", "value": "user-uuid-001" }]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "4 · Audio Variants",
      "description": "Procesamiento no destructivo: pitch shift (±12st) y/o cambio de tempo (0.5x–2.0x).\nEl archivo original audio.wav nunca se modifica.\nSi la variante ya existe se devuelve directamente (caché).",
      "item": [
        {
          "name": "Generate – pitch +2st",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/audio-variants",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "audio-variants"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pitchShift\": 2,\n  \"tempo\": 1.0\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "201 – Generando (status: processing)",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\",\n  \"videoId\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"pitchShift\": 2,\n  \"tempo\": 1,\n  \"filePath\": null,\n  \"status\": \"processing\",\n  \"processingEngine\": null,\n  \"errorMessage\": null,\n  \"createdAt\": \"2026-02-24T00:15:00.000Z\"\n}"
            },
            {
              "name": "200 – Cache hit (status: ready)",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\",\n  \"videoId\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298\",\n  \"pitchShift\": 2,\n  \"tempo\": 1,\n  \"filePath\": \"4042ee35-60b6-4e8a-8dc6-e21a86436298/processed/pitch+2.wav\",\n  \"status\": \"ready\",\n  \"processingEngine\": \"asetrate\",\n  \"errorMessage\": null,\n  \"createdAt\": \"2026-02-24T00:15:00.000Z\"\n}"
            },
            {
              "name": "400 – pitchShift=0 y tempo=1.0 (sin cambio)",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"statusCode\": 400,\n  \"message\": \"pitchShift=0 y tempo=1.0 no requieren procesamiento; usa el audio original.\"\n}"
            }
          ]
        },
        {
          "name": "Generate – pitch -3st, tempo 0.75x",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/audio-variants",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "audio-variants"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pitchShift\": -3,\n  \"tempo\": 0.75\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Generate – solo tempo 1.5x",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/audio-variants",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "audio-variants"]
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pitchShift\": 0,\n  \"tempo\": 1.5\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Get all variants of a video",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/video/{{videoId}}/audio-variants",
              "host": ["{{baseUrl}}"],
              "path": ["video", "{{videoId}}", "audio-variants"]
            }
          },
          "response": [
            {
              "name": "200 – Lista de variantes",
              "status": "OK",
